rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ CrediPay High-Security Perimeter
    // Robust, recursive user isolation logic.
    
    // This match covers:
    // 1. /users/{userId} (The main merchant doc)
    // 2. /users/{userId}/... (All nested subcollections)
    match /users/{userId}/{allPaths=**} {
       allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Explicit fallback for root user document
    match /users/{userId} {
       allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Secondary fallback for any collection-group style queries (if used)
    match /{path=**}/transactions/{document=**} {
       allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}